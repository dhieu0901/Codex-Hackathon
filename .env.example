#   cp .env.example .env.local
#
# ⚠️ KHÔNG commit .env.local (đã có trong .gitignore)
# ============================================

# OpenAI API Key (bắt buộc)
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
